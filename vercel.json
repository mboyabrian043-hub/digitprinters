{
    "rewrites": [
        { "source": "/auth/callback", "destination": "/index.html" },
        { "source": "/callback", "destination": "/index.html" },
        { "source": "/dashboard", "destination": "/index.html" },
        { "source": "/free-bots", "destination": "/index.html" },
        { "source": "/analysis-tool", "destination": "/index.html" },
        { "source": "/endpoint", "destination": "/index.html" },
        { "source": "/(.*)", "destination": "/index.html" }
    ],
    "headers": [
        {
            "source": "/static/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        }
    ]
}
